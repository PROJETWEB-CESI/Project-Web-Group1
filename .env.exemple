# ================================================
# NovaCampus Alliance - Environment Variables
# ================================================

# ===================== DATABASES =====================
# PostgreSQL
POSTGRES_USER=nova
POSTGRES_PASSWORD=nova123
POSTGRES_DB=novacampus
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# MongoDB
MONGO_URI=mongodb://mongo:27017/novacampus

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# ===================== JWT & AUTH =====================
JWT_SECRET=super_long_random_secret_key_change_this_in_production_please
# Short-lived access token (used for API calls, httpOnly cookie)
ACCESS_TOKEN_EXPIRES_IN=15m
# Longer-lived refresh token (httpOnly cookie, used to obtain new access tokens)
REFRESH_TOKEN_EXPIRES_IN=2d

# ===================== SERVICES URLS (Internal) =====================
# Used by frontend and between services
GATEWAY_URL=http://gateway:80
IAM_SERVICE_URL=http://iam-service:3000
ACADEMIC_SERVICE_URL=http://academic-service:3000
SCHEDULING_SERVICE_URL=http://scheduling-service:3000
BILLING_SERVICE_URL=http://billing-service:3000
REPORTING_SERVICE_URL=http://reporting-service:3000
AI_AGENT_URL=http://ai-agent-service:8000

# ===================== FRONTEND =====================
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Dev proxy target for Next.js rewrites (when running frontend dev server directly on :3000).
# - Local host dev (outside docker): leave default or set to http://localhost:8080
# - Inside `docker compose`: set to the internal docker service so Next can reach gateway.
# This is automatically set in docker-compose.yml for the frontend service.
# DEV_API_PROXY_TARGET=http://gateway:80

# ===================== AI AGENT =====================
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2

# ===================== DEVELOPMENT =====================
NODE_ENV=development

# Optional: Ollama (if you want to run it locally outside Docker)
# OLLAMA_HOST=http://localhost:11434
# ===================== TEST / DEV CREDENTIALS (IAM only) =====================
# Set to true to automatically seed test user accounts on IAM service startup.
# Set to false (or omit) to *remove* any existing test accounts (so the credentials stop working).
# These allow easy testing of role-based features without manual registration.
# NEVER enable in production environments!
# If the variable is omitted from .env, set to empty, "false", or any other value, it defaults to false (test accounts removed if present).
ENABLE_TEST_CREDENTIALS=false
#
# IMPORTANT: Environment variables are injected into the container ONLY at creation time.
# After editing this value, you MUST recreate the iam-service:
#   docker compose up -d --force-recreate iam-service
# (or the full stack). Otherwise the running container keeps the previous value.
# The code accepts "true", "1", "yes" (case-insensitive) for ON; everything else (incl. missing) = OFF (accounts removed).

# When enabled, use these credentials to log in (via the login page or API):
# - Student:   student@test.com   / student123     (role: student,   campus: CAMP001)
# - Teacher:   teacher@test.com   / teacher123     (role: teacher,   campus: CAMP001)
# - Admin:     admin@test.com     / admin123       (role: admin,     campus: CAMP001)
# - Executive: executive@test.com / executive123   (role: executive, campus: CAMP001)
#
# After login you will be redirected to the role-specific dashboard.
